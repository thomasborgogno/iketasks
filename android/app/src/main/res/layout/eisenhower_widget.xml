<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:orientation="vertical"
    android:padding="12dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Matrice di Eisenhower"
            android:textColor="#0D1B2A"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Importante e Urgente"
            android:textColor="#D7263D"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/q1_tasks"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nessuna task"
            android:textColor="#333333"
            android:textSize="12sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Importante ma Non Urgente"
            android:textColor="#1B998B"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/q2_tasks"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nessuna task"
            android:textColor="#333333"
            android:textSize="12sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Non Importante ma Urgente"
            android:textColor="#F4A261"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/q3_tasks"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nessuna task"
            android:textColor="#333333"
            android:textSize="12sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Non Importante e Non Urgente"
            android:textColor="#457B9D"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/q4_tasks"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nessuna task"
            android:textColor="#333333"
            android:textSize="12sp" />

</LinearLayout>
